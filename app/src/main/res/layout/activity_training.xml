<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/bg_light">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/gradient_header" android:gravity="center_vertical" android:padding="20dp" android:paddingTop="40dp">
        <ImageButton android:id="@+id/btnBack" android:layout_width="36dp" android:layout_height="36dp" android:src="@android:drawable/ic_menu_revert" android:background="?attr/selectableItemBackgroundBorderless" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🎓 Training Mode" android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold" android:layout_marginStart="12dp" />
    </LinearLayout>

    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="16dp" app:cardCornerRadius="16dp" app:cardElevation="3dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Add Training ECG" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/primary" />
            <ImageView android:id="@+id/ivTrainPreview" android:layout_width="match_parent" android:layout_height="120dp" android:scaleType="centerCrop" android:layout_marginTop="8dp" android:visibility="gone" />
            <Button android:id="@+id/btnPickImage" android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="8dp" android:text="🖼️ Select ECG Image" android:backgroundTint="@color/primary" />
            <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="Known Diagnosis">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etDiagnosis" android:layout_width="match_parent" android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:hint="Notes (optional)">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etNotes" android:layout_width="match_parent" android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>
            <Button android:id="@+id/btnSaveTraining" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="8dp" android:text="💾 Save" android:backgroundTint="#4CAF50" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📋 Training History" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/text_primary" android:paddingStart="20dp" android:paddingTop="8dp" />
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvTraining" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:padding="12dp" />
</LinearLayout>
